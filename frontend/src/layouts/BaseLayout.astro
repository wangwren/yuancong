---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonical && <link rel="canonical" href={canonical} />}
    <script is:inline>
      // 防闪：首帧渲染前定主题。优先访客记忆的选择，其次夜间时段（20-5 点）自动深色
      (function () {
        var saved = localStorage.getItem('theme');
        var h = new Date().getHours();
        var dark = saved ? saved === 'dark' : (h >= 20 || h < 5);
        if (dark) document.documentElement.classList.add('dark');
      })();
    </script>
    <style is:inline>
      /* 防闪之二：画布颜色不依赖外部样式表——跨文档导航时新文档 CSS 尚未应用的
         首帧窗口里，浏览器按 color-scheme 画默认画布，缺省是白色（深色模式下即闪白）。
         颜色值必须与全局 token --a-bg 保持一致（smoke 有对拍断言防漂移） */
      html { background: hsl(0 0% 100%); color-scheme: light; }
      html.dark { background: hsl(223 25% 9%); color-scheme: dark; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
