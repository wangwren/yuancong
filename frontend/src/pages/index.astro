---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkyBand from '../components/SkyBand.astro';
import SiteNav from '../components/SiteNav.astro';
import Hero from '../components/Hero.astro';
import RecentPosts from '../components/RecentPosts.astro';
import ContactCard from '../components/ContactCard.astro';
import Confetti from '../components/Confetti.astro';
import Crawler from '../components/Crawler.astro';
---

<BaseLayout
  title="yuancong.ai — 小从"
  description="一个程序员，也是爱折腾产品的人。白天写服务端，晚上写点感兴趣的东西。"
>
  <SkyBand />
  <div class="page">
    <SiteNav />
    <Hero />
    <RecentPosts />
    <ContactCard />
    <footer>© 2026 <span class="mini"><span class="y">yuan</span> ∘ <span class="c">cong</span></span></footer>
  </div>
  <Confetti />
  <Crawler />
</BaseLayout>

<style>
  footer {
    border-top: 1px solid var(--a-line);
    padding: 1.5rem 0 2rem; text-align: center;
    color: var(--a-muted); font-size: .82rem; position: relative; z-index: 1;
  }
  footer .mini { font-family: "Baloo 2", sans-serif; }
  footer .mini .y { color: var(--a-secondary); }
  footer .mini .c { color: var(--a-primary); }
</style>
