---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import SeriesNav from '../../components/SeriesNav.astro';
import { seriesOf } from '../../lib/series';
import { readingMinutes } from '../../lib/reading-time';
import { GUIDE_TOOLS } from '../../lib/guide';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // id 扁平化的两类冲突在此拦下（glob 对 id 相撞只静默去重，不报错）：
  // 文件名跨目录重复 → 文章悄悄丢失；文章 slug 撞系列目录名 → 与 [series] 路由相撞
  const files = Object.keys(import.meta.glob('../../content/blog/**/*.md'));
  if (files.length !== posts.length)
    throw new Error(`文章数（${posts.length}）与文件数（${files.length}）不一致：应是文件名跨目录重复导致 id 冲突`);
  const seriesKeys = new Set(posts.map(seriesOf).filter((s) => s !== null));
  const clash = posts.find((p) => seriesKeys.has(p.id));
  if (clash) throw new Error(`文章 slug「${clash.id}」与系列目录名冲突，请改文件名`);
  const reserved = new Set<string>(GUIDE_TOOLS.map((t) => t.key));
  const hitReserved = posts.find((p) => reserved.has(p.id));
  if (hitReserved) throw new Error(`文章 slug「${hitReserved.id}」与 Guide 镜像路由冲突，请改文件名`);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const fmtDate = post.data.pubDate.toISOString().slice(0, 10);

// 所属系列与同系列文章（按发布升序 = 阅读顺序）；零散文章不渲染系列卡
const series = seriesOf(post);
const seriesPosts = series
  ? (await getCollection('blog'))
      .filter((p) => seriesOf(p) === series)
      .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf())
  : [];

const readMinutes = readingMinutes(post.body ?? '');
---

<ArticleLayout title={`${post.data.title} — yuancong.ai`} description={post.data.description}
               backHref="/blog/" backLabel="全部文章" headings={headings}>
  <header class="post-head" slot="head">
    <h1>{post.data.title}</h1>
    <p class="meta">
      {post.data.tags.map((t) => <span class="tag">{t}</span>)}
      <span class="stat">{readMinutes} min read</span>
      <time datetime={fmtDate}>{fmtDate}</time>
    </p>
  </header>
  <Content />
  {series && <SeriesNav slot="foot" name={series} posts={seriesPosts} currentId={post.id} />}
</ArticleLayout>

<style>
  .post-head { margin: 0 0 1.5rem; padding-bottom: 1.1rem; border-bottom: 2px dashed var(--a-line); }
  h1 { margin: 0 0 .45em; font-size: clamp(1.55rem, 3.4vw, 2.25rem); line-height: 1.3; }
  .meta { display: flex; flex-wrap: wrap; align-items: center; gap: .6rem; margin: 0; }
  /* 阅读决策信息（标签+时长）归左，档案信息（日期）归右——与列表页卡片同布局 */
  .meta time, .stat { color: var(--a-muted); font-size: .85rem; font-variant-numeric: tabular-nums; white-space: nowrap; }
  .tag + .stat::before { content: '·'; margin-right: .6rem; }  /* 无标签文章不出孤立点号 */
  .meta time { margin-left: auto; }
  .tag {
    font-size: .7rem; font-weight: 700; letter-spacing: .03em;
    background: var(--a-chip); color: var(--a-chip-ink);
    border-radius: 999px; padding: .16em .7em;
  }
</style>
