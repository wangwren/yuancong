---
// 全宽天空带：漂云（浅色）+ 星空（深色可见）。天色随访客本地时段：
// 晨昏改色（body.sky-dawn / body.sky-dusk），夜间自动深色由 BaseLayout 内联脚本负责。
// height：首页 30rem（默认），内页 15rem 矮版——全站统一「天空 → 内容」结构。
// 云 / 星最低位控制在带内，矮版底部渐隐遮罩兜住。
interface Props { height?: string }
const { height = '30rem' } = Astro.props;

// 星场：构建时用固定种子伪随机生成（确定性、纯静态、零运行时 JS）。
// 真夜空感 = 繁密 + 随机分布 + 亮度分层（多微光 / 少亮星带光晕）+ 各自错开、深浅不一的细腻闪烁。
function mulberry32(seed: number) {
  return function () {
    seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(20260720);
const STAR_COUNT = 78;
const stars = Array.from({ length: STAR_COUNT }, () => {
  const tier = rand();
  const r2 = rand();
  let sz: number, oMin: number, oMax: number, glow: boolean;
  if (tier < 0.66) {                 // 微光小星（多）——几乎不闪，压住整体不浮夸
    sz = 4 + r2 * 2.5; oMin = 0.12 + rand() * 0.12; oMax = 0.34 + rand() * 0.16; glow = false;
  } else if (tier < 0.9) {           // 中等星
    sz = 6.5 + r2 * 3; oMin = 0.24 + rand() * 0.13; oMax = 0.58 + rand() * 0.2; glow = false;
  } else {                           // 亮星（少）——更大、带柔光晕，负责「闪烁」的存在感
    sz = 9.5 + r2 * 5; oMin = 0.4 + rand() * 0.2; oMax = 0.88 + rand() * 0.12; glow = true;
  }
  const left = rand() * 100;
  const top = 0.5 + Math.pow(rand(), 1.8) * 22;   // rem：向上聚集（远离下方内容 / 地平线）
  const td = 2.6 + rand() * 4.6;                  // 周期各异，避免齐刷刷同步脉动
  const tw = -rand() * 9;                         // 起始相位打散
  const hr = rand();                              // 微弱色温差：多冷白、少暖白
  const hue = hr < 0.62 ? 220 : hr < 0.82 ? 45 : 205;
  const sat = hr < 0.62 ? 18 : 60;
  return { left, top, sz, oMin, oMax, glow, td, tw, hue, sat };
});
---

<div class="skyband" style={`--sky-h: ${height}`} aria-hidden="true">
  <div class="cloud c1"></div>
  <div class="cloud c2"></div>
  <div class="cloud c3"></div>
  {stars.map((s) => (
    <span
      class={s.glow ? 'star big' : 'star'}
      style={`left:${s.left.toFixed(2)}%;top:${s.top.toFixed(2)}rem;--sz:${s.sz.toFixed(1)}px;--td:${s.td.toFixed(1)}s;--tw:${s.tw.toFixed(1)}s;--omin:${s.oMin.toFixed(2)};--omax:${s.oMax.toFixed(2)};--c:hsl(${s.hue} ${s.sat}% 92%)`}
    ></span>
  ))}
</div>

<style>
  .skyband {
    position: absolute; left: 0; right: 0; top: 0; height: var(--sky-h, 30rem);
    background: linear-gradient(to bottom, var(--a-sky), transparent);
    pointer-events: none; overflow: hidden;
    transition: background .35s cubic-bezier(.41,.1,.13,1);
    /* 底部渐隐遮罩：矮版（15rem）下云的模糊光晕会越过带底被 overflow 硬切出一条横线，
       让最后 5rem 平滑淡出。30rem 首页带此区间本就近乎全透明，视觉零变化 */
    -webkit-mask-image: linear-gradient(to bottom, #000 calc(100% - 5rem), transparent);
    mask-image: linear-gradient(to bottom, #000 calc(100% - 5rem), transparent);
    /* 跨页过渡「壳层静止」：天空带独立于 root 切换，首页↔内页高度差
       （30rem↔15rem）由过渡组连续形变（design.md §8 跨页） */
    view-transition-name: sky-band;
  }
  .cloud {
    position: absolute; background: var(--a-cloud);
    border-radius: 50%; filter: blur(28px);
    transition: background-color .35s cubic-bezier(.41,.1,.13,1);
  }
  .cloud.c1 { width: 20rem; height: 5.5rem; top: 3.5rem; left: -6rem; animation: drift 95s linear infinite; }
  .cloud.c2 { width: 14rem; height: 4rem; top: 10rem; left: 30%; animation: drift 140s linear -40s infinite; }
  .cloud.c3 { width: 24rem; height: 6rem; top: 5.5rem; left: 65%; animation: drift 115s linear -80s infinite; }
  @keyframes drift { from { transform: translateX(-12rem); } to { transform: translateX(105vw); } }
  @media (prefers-reduced-motion: reduce) { .cloud { animation: none; } }

  /* 星星：四角星芒 ✦（不是圆点），clip-path 细长四芒。默认隐藏（浅色不显），
     深色下各自错相位、深浅不一地闪烁；亮星用 drop-shadow 沿星形发柔光晕 */
  .star {
    position: absolute;
    width: var(--sz, 3px); height: var(--sz, 3px);
    background: var(--c, hsl(220 20% 92%)); opacity: 0;
    clip-path: polygon(50% 0, 54% 46%, 100% 50%, 54% 54%, 50% 100%, 46% 54%, 0 50%, 46% 46%);
  }
  .star.big { filter: drop-shadow(0 0 calc(var(--sz, 9px) * .45) var(--c, hsl(45 60% 90%))); }
  :global(html.dark) .star {
    animation: twinkle var(--td, 3.6s) ease-in-out var(--tw, 0s) infinite;
  }
  @keyframes twinkle {
    0%, 100% { opacity: var(--omin, .2); }
    50% { opacity: var(--omax, .8); }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.dark) .star { animation: none; opacity: var(--omax, .55); }
  }
</style>

<script>
  const h = new Date().getHours();
  if (h >= 5 && h < 8) document.body.classList.add('sky-dawn');
  else if (h >= 17 && h < 20) document.body.classList.add('sky-dusk');
</script>
