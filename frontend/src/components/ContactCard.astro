---
// 联系区：三枚玩具盒胶囊按钮（GitHub / X 外链，公众号 hover 弹二维码）。
// 邮箱入口已撤（2026-07-14 定：不开 Email Routing，联系走社交入口）。
// RSS 等有了真实去处再加，不挂空链接。
---

<div class="contact rise" style="--d:440ms">
  <p class="line">想聊技术、聊产品，或者只是打个招呼 ——</p>
  <div class="socials">
    <a class="pill" href="https://github.com/wangwren" rel="me"><span class="pill-in">GitHub</span></a>
    <a class="pill" href="https://x.com/debug_dog61749" rel="me"><span class="pill-in">X / Twitter</span></a>
    <span class="pill wechat" tabindex="0"><span class="pill-in">公众号</span><span class="qr-pop">
      <img src="/images/wechat-qr.jpg" alt="微信公众号二维码" width="172" height="172" loading="lazy" />
      <span class="qr-hint">微信扫一扫</span>
    </span></span>
  </div>
</div>

<style>
  /* 不设 z-index：设了会把整个联系区变成层叠上下文，弹层的 z-index 被封在里面
     出不来（对外按 1 比，输给毛毛虫的 30）。压住天空带靠「定位元素 + DOM 在后」即可 */
  .contact { position: relative; text-align: center; padding: 1.8rem 0 4rem; }
  .contact .line { color: var(--a-muted); font-size: .98rem; margin: 0 0 1.4rem; }
  .socials { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; }

  /* 命中区域（外层）静止不动，动画只发生在内层 —— 同文章卡片，避免 hover 位移抖动；
     二维码弹层也锚在静止外层上，悬停时不跟着按钮跳 */
  .pill { display: inline-block; text-decoration: none; border-radius: 999px; }
  .pill-in {
    display: inline-block; font-weight: 700; font-size: .95rem;
    color: var(--a-ink); background: var(--a-bg);
    border: 3px solid var(--a-ink); border-radius: 999px;
    padding: .58rem 1.35rem;
    box-shadow: 0 4px 0 var(--a-ink);
    transition: transform .18s cubic-bezier(.2,.7,.3,1.4), box-shadow .18s ease,
                background-color .35s, border-color .35s, color .35s;
  }
  .pill:hover .pill-in, .pill:focus-visible .pill-in {
    transform: translateY(-3px) rotate(-1deg);
    box-shadow: 0 8px 0 var(--a-ink);
    color: var(--a-primary);
  }
  .socials .pill:nth-child(even):hover .pill-in,
  .socials .pill:nth-child(even):focus-visible .pill-in {
    transform: translateY(-3px) rotate(1deg);
  }

  /* 公众号：悬停 / 聚焦弹出二维码卡片（玩具盒语言：粗描边 + 硬阴影，微弹入场） */
  .wechat { position: relative; cursor: default; }
  .wechat:focus-within .pill-in {
    transform: translateY(-3px) rotate(-1deg);
    box-shadow: 0 8px 0 var(--a-ink);
    color: var(--a-primary);
  }
  .qr-pop {
    position: absolute; left: 50%; bottom: calc(100% + .8rem);
    display: block; padding: .6rem .6rem .45rem;
    background: var(--a-bg);
    border: 3px solid var(--a-ink); border-radius: 1rem;
    box-shadow: 0 4px 0 var(--a-ink);
    opacity: 0; visibility: hidden;
    transform: translateX(-50%) translateY(6px) scale(.92);
    transform-origin: bottom center;
    transition: opacity .18s ease, visibility .18s,
                transform .18s cubic-bezier(.2,.7,.3,1.4),
                background-color .35s, border-color .35s, box-shadow .35s;
    z-index: 50; /* 浮层盖过毛毛虫（30）与卡片，避免层级穿插 */
  }
  /* 指向「公众号」的小箭头尾巴：与弹层同款描边，从属关系一目了然 */
  .qr-pop::after {
    content: ""; position: absolute; left: 50%; bottom: -8.5px;
    width: 12px; height: 12px;
    background: var(--a-bg);
    border-right: 3px solid var(--a-ink); border-bottom: 3px solid var(--a-ink);
    transform: translateX(-50%) rotate(45deg);
    border-bottom-right-radius: 3px;
  }
  .wechat:hover .qr-pop, .wechat:focus .qr-pop, .wechat:focus-within .qr-pop {
    opacity: 1; visibility: visible;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .qr-pop img { display: block; width: 172px; height: 172px; border-radius: .4rem; }
  .qr-hint { display: block; text-align: center; font-size: .72rem; color: var(--a-muted); margin-top: .3rem; }
  @media (prefers-reduced-motion: reduce) {
    .qr-pop { transition: opacity .18s ease, visibility .18s; transform: translateX(-50%); }
    .wechat:hover .qr-pop, .wechat:focus .qr-pop, .wechat:focus-within .qr-pop { transform: translateX(-50%); }
  }
</style>

<script>
  // 入场动画播完即摘掉 rise 类：opacity/transform 动画在播放期间会把容器
  // 变成层叠上下文，二维码弹层的 z-index 会被封在里面、压到毛毛虫和卡片之下。
  // 摘类后视觉无差异（backwards 填充结束后本就是自然样式），层级永久正确
  const contact = document.querySelector<HTMLElement>('.contact')!;
  contact.addEventListener('animationend', (e) => {
    if (e.target === contact) contact.classList.remove('rise');
  }, { once: true });
</script>
