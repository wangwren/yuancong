---
// 文章目录：depth 2-4 的标题列表。宽屏（≥1440px）悬浮在文章纸右缘外常开，
// 更窄视口由 [slug].astro 里的脚本收起为纸内顶部折叠条。
import type { MarkdownHeading } from 'astro';

interface Props { headings: MarkdownHeading[] }
const { headings } = Astro.props;
---

<details class="toc" open>
  <summary>目录</summary>
  <nav>
    <ul>
      {headings.map((h) => (
        <li class={`d${h.depth}`}><a href={`#${h.slug}`} title={h.text}>{h.text}</a></li>
      ))}
    </ul>
  </nav>
</details>

<style>
  /* 窄屏折叠态在纸内，走安静样式（细线框、无阴影），不与正文抢视觉重量 */
  .toc {
    border: 2px solid var(--a-line); border-radius: .9rem;
    padding: .6rem .95rem; font-size: .84rem;
  }
  summary { font-weight: 700; cursor: pointer; color: var(--a-ink); }
  nav { margin-top: .5rem; }
  /* 主干竖线贯穿一级项圆点（目录树的脊柱） */
  ul { list-style: none; margin: 0; padding: 0; position: relative; }
  ul::before {
    content: ''; position: absolute; left: 3px; top: .55em; bottom: .55em;
    width: 1.5px; background: var(--a-line);
  }
  li { position: relative; margin: .5em 0; line-height: 1.45; }
  /* 条目两行截断：超出两行显示 …，title 存全文 */
  a {
    color: var(--a-muted); text-decoration: none;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  a:hover { color: var(--a-primary); }
  a.now { color: var(--a-primary); font-weight: 700; }              /* 阅读位置联动高亮 */
  /* 一级（h2）：实心圆点骑主干线 + 悬挂缩进（第二行对齐首行文字） */
  li.d2 { padding-left: 1.15em; }
  li.d2::before {
    content: ''; position: absolute; left: 0; top: .5em;
    width: 7px; height: 7px; border-radius: 50%; background: var(--a-muted);
  }
  /* 二 / 三级（h3/h4）：└ 连接符从主干拐入 + 递进缩进 */
  li.d3 { padding-left: 2.1em; }
  li.d4 { padding-left: 3.1em; }
  li.d3::before, li.d4::before {
    content: ''; position: absolute; top: -.05em;
    width: .55em; height: .82em;
    border-left: 1.5px solid var(--a-line); border-bottom: 1.5px solid var(--a-line);
    border-bottom-left-radius: 4px;
  }
  li.d3::before { left: .7em; }
  li.d4::before { left: 1.7em; }
  /* 当前项：圆点 / 连接符 / 文字同步主色 */
  li.d2:has(a.now)::before { background: var(--a-primary); }
  li.d3:has(a.now)::before, li.d4:has(a.now)::before { border-color: var(--a-primary); }
  /* 宽屏：悬浮到 57rem 文章纸右缘外的页底空白区，正文不让位；无框通透。
     纸半宽 28.5rem + 1rem 间距，栏宽 14.5rem → 右缘在 50%+44rem，需视口 ≥ 约 1423px */
  @media (min-width: 1440px) {
    .toc {
      position: fixed; top: 9.5rem;   /* 与文章纸顶边平齐 */
      left: calc(50% + 29.5rem); width: 14.5rem;
      max-height: calc(100vh - 11.5rem); overflow-y: auto;
      background: transparent; border: none; box-shadow: none;
      padding: .2rem 0 .2rem .1rem;
    }
    summary { pointer-events: none; }  /* 宽屏常开，不给折叠 */
  }
</style>

<script>
  // 阅读位置联动：视口顶下 120px 作为阅读线，高亮最后一个越过它的标题。
  // 用 scroll + rAF 而非 IntersectionObserver：长段落中标题都不在视口时 IO 不发新事件，
  // 需要额外记忆状态才能对；直接扫标题位置（每篇至多几十个）逻辑直白且始终正确
  // 链接与标题成对过滤：若某 slug 找不到对应 id，链接与标题分开过滤会整体错位一格
  const pairs = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc nav a'))
    .map((a) => [a, document.getElementById(decodeURIComponent(a.hash.slice(1)))] as const)
    .filter((p): p is readonly [HTMLAnchorElement, HTMLElement] => p[1] !== null);
  let ticking = false;
  function spy() {
    ticking = false;
    let cur = -1;
    for (let i = 0; i < pairs.length; i++) {
      if (pairs[i][1].getBoundingClientRect().top <= 120) cur = i;
    }
    pairs.forEach(([a], i) => {
      a.classList.toggle('now', i === cur);
      if (i === cur) a.setAttribute('aria-current', 'true');
      else a.removeAttribute('aria-current');
    });
  }
  addEventListener('scroll', () => {
    if (!ticking) { ticking = true; requestAnimationFrame(spy); }
  }, { passive: true });
  spy();
</script>
