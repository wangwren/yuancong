---
// Guide「本系列」章节导航：按官方阅读站同构的章节分组（chapters.json 随同步产物走），
// 当前篇所在章默认展开、其余收起（同 TOC 的 details 折叠语言）。
// 卡片壳与定位同博客 SeriesNav：宽屏 ≥1440px 悬浮纸左缘外与右侧 TOC 镜像，窄屏纸内文末。
import type { CollectionEntry } from 'astro:content';
import { chapterGroups } from '../lib/guide';
import '../styles/side-card.css';
import '../styles/fold.css';

interface Props {
  name: string;                       // 工具显示名（Claude Code / Codex）
  tool: string;                       // 工具 key = content/guide 子目录名
  posts: CollectionEntry<'guide'>[];  // 同工具全部篇目（编号升序）
  currentId: string;
}
const { name, tool, posts, currentId } = Astro.props;
const chapters = chapterGroups(tool, posts);
---

<nav class="series" aria-label={`系列：${name}`}>
  <p class="s-head">本系列 · {name}</p>
  {chapters.map((c) => (
    <details class="chap fold" open={c.items.some((p) => p.id === currentId) || undefined}>
      <summary>{c.title}</summary>
      <ul>
        {c.items.map((p) => (
          <li>
            {p.id === currentId
              ? <span aria-current="page" title={p.data.title}>{p.data.title}</span>
              : <a href={`/blog/${p.id}/`} title={p.data.title}>{p.data.title}</a>}
          </li>
        ))}
      </ul>
    </details>
  ))}
</nav>

<style>
  /* 卡片壳/链接/两行截断/宽屏几何见 styles/side-card.css，开合动画见 styles/fold.css（共享）。
     本组件加「章 > 篇」树：章内篇目挂在一条主干线上、每篇 └ 连接符指引（对齐右侧 TOC 树语言） */
  .chap { margin: .15rem 0; }
  summary { cursor: pointer; font-weight: 700; color: var(--a-muted); padding: .2em 0; }
  summary:hover { color: var(--a-primary); }
  .chap[open] > summary { color: var(--a-ink); }
  /* 章内篇目列表：左侧主干竖线 + 每篇 └ 连接符 */
  ul { list-style: none; margin: .1em 0 .5em; padding-left: 1.35em; position: relative; }
  ul::before {
    content: ''; position: absolute; left: .5em; top: 0; bottom: .35em;
    width: 1.5px; background: var(--a-line);
  }
  li { position: relative; }
  li::before {
    content: ''; position: absolute; left: -.85em; top: .02em;
    width: .5em; height: .78em;
    border-left: 1.5px solid var(--a-line); border-bottom: 1.5px solid var(--a-line);
    border-bottom-left-radius: 4px;
  }
  li:has(> span[aria-current])::before { border-color: var(--a-primary); }
</style>
