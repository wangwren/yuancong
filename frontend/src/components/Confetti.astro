---
// 点击空白撒花：10 粒彩纸抛物线飘落后自清理。命中链接/按钮或 reduced-motion 时不触发。
// 粒子是动态创建元素，样式必须全局。
---

<style is:global>
  .bit {
    position: absolute; z-index: 40; pointer-events: none;
    width: 8px; height: 8px; border-radius: 2px;
  }
</style>

<script>
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const COLORS = ['hsl(240 95% 62%)', 'hsl(333 100% 45%)', 'hsl(200 80% 70%)', 'hsl(45 95% 60%)'];
  document.body.addEventListener('click', (e) => {
    if ((e.target as Element).closest('a,button')) return;
    if (reduced) return;
    // 粒子挂 body（已定位），pageX/Y 即含滚动量的定位坐标
    const x = e.pageX;
    const y = e.pageY;
    for (let i = 0; i < 10; i++) {
      const bit = document.createElement('span');
      bit.className = 'bit';
      bit.style.left = x + 'px';
      bit.style.top = y + 'px';
      bit.style.background = COLORS[i % COLORS.length];
      document.body.appendChild(bit);
      const ang = Math.random() * Math.PI * 2;
      const dist = 40 + Math.random() * 70;
      const dx = Math.cos(ang) * dist;
      const dy = Math.sin(ang) * dist - 30;
      const rot = (Math.random() - 0.5) * 540;
      const anim = bit.animate([
        { transform: 'translate(-50%,-50%)', opacity: 1 },
        { transform: `translate(calc(-50% + ${dx}px), calc(-50% + ${dy + 70}px)) rotate(${rot}deg)`, opacity: 0 },
      ], { duration: 800 + Math.random() * 500, easing: 'cubic-bezier(.2,.6,.4,1)' });
      anim.onfinish = () => bit.remove();
    }
  });
</script>
