---
// 打字机标题：.ch 逐字占位（布局不跳动），点亮动画脚本见 Task 6
---

<div class="hero">
  <h1 id="typing"><span class="ch">你</span><span class="ch">好</span><span class="ch">，</span><span class="ch">我</span><span class="ch">是</span><span class="me"><span class="ch">小</span><span class="ch">从</span></span><span class="ch">。</span></h1>
  <p class="intro rise" style="--d:200ms">一个程序员，也是爱折腾产品的人。白天写服务端，晚上写点感兴趣的东西。</p>
</div>

<style>
  .hero { position: relative; z-index: 1; padding: 5rem 0 4.2rem; text-align: center; }
  h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem); line-height: 1.18; margin: 0 0 1.2rem;
    font-weight: 700; letter-spacing: .01em;
  }
  h1 .me {
    color: var(--a-primary);
    text-decoration: underline wavy var(--a-secondary) 3px;
    text-underline-offset: .22em;
  }
  h1 .ch { opacity: 0; }
  h1 .ch.on { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    h1 .ch { opacity: 1; }
  }
  .hero p.intro { max-width: 30em; margin: 0 auto; color: var(--a-muted); font-size: 1.08rem; }
</style>

<script>
  // 打字机：逐字点亮（占位不变避免布局跳动），逗号后停顿一拍像真人换气
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const chars = Array.from(document.querySelectorAll<HTMLElement>('#typing .ch'));
  if (!reduced && chars.length > 0) {
    const caret = document.createElement('span');
    caret.className = 'type-caret';
    let i = 0;
    const typeNext = () => {
      if (i >= chars.length) {
        setTimeout(() => caret.remove(), 2200);
        return;
      }
      const ch = chars[i++];
      ch.classList.add('on');
      ch.insertAdjacentElement('afterend', caret);
      const delay = ch.textContent === '，' ? 680 : 130 + Math.random() * 110;
      setTimeout(typeNext, delay);
    };
    setTimeout(typeNext, 500);
  }
</script>

<!-- 光标由脚本动态创建，拿不到组件作用域标记，样式必须全局 -->
<style is:global>
  .type-caret {
    display: inline-block; width: 3px; height: .92em;
    background: var(--a-secondary);
    margin-left: .06em; vertical-align: -.08em;
    animation: blink .85s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .type-caret { display: none; } }
</style>
