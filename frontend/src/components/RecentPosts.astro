---
// 「最近在写」：构建时从 blog 集合取最新 4 篇。P2 起卡片可点进详情。
import { getCollection } from 'astro:content';
import PostCard from './PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<section class="writing rise" style="--d:340ms">
  <div class="block-head">
    <h2><span class="dot"></span><span>最近在写</span></h2>
    <a class="more" href="/blog/">全部文章 →</a>
  </div>
  <div class="posts">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</section>

<style>
  .writing { position: relative; z-index: 1; padding: .5rem 0 2.5rem; }
  .block-head { display: flex; align-items: baseline; gap: .7rem; margin-bottom: 1.4rem; }
  .block-head h2 { margin: 0; font-size: 1.3rem; display: flex; align-items: center; gap: .5rem; }
  .block-head .dot { width: .62em; height: .62em; border-radius: 50%; background: var(--a-primary); flex-shrink: 0; }
  .block-head .more {
    margin-left: auto; font-size: .86rem; font-weight: 700;
    color: var(--a-primary); text-decoration: none;
  }
  .block-head .more:hover { text-decoration: underline wavy var(--a-secondary) 2px; text-underline-offset: .3em; }
  .posts { display: grid; grid-template-columns: 1fr; gap: 1.4rem; }
  @media (min-width: 820px) { .posts { grid-template-columns: 1fr 1fr; gap: 1.6rem; } }
</style>
